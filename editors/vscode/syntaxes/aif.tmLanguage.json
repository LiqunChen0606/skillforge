{
  "scopeName": "source.aif",
  "patterns": [
    { "include": "#metadata" },
    { "include": "#blocks" },
    { "include": "#inline" },
    { "include": "#code" },
    { "include": "#table" }
  ],
  "repository": {
    "metadata": {
      "match": "^#(\\w+):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.other.metadata.aif" },
        "2": { "name": "string.unquoted.metadata-value.aif" }
      }
    },
    "blocks": {
      "patterns": [
        {
          "match": "^\\s*@(section|skill|claim|evidence|definition|theorem|assumption|result|conclusion|requirement|recommendation|callout|table|figure|audio|video|precondition|step|verify|fallback|example|decision|red_flag|output_contract|tool|scenario)(\\[.*?\\])?(:\\s*.*)?$",
          "captures": {
            "1": { "name": "keyword.control.block.aif" },
            "2": { "name": "entity.other.attribute.aif" },
            "3": { "name": "string.unquoted.block-title.aif" }
          }
        },
        {
          "match": "^\\s*@end\\s*$",
          "name": "keyword.control.end.aif"
        }
      ]
    },
    "inline": {
      "patterns": [
        { "match": "\\*\\*[^*]+\\*\\*", "name": "markup.bold.aif" },
        { "match": "\\*[^*]+\\*", "name": "markup.italic.aif" },
        { "match": "`[^`]+`", "name": "markup.inline.raw.aif" }
      ]
    },
    "code": {
      "begin": "^```(\\w*)$",
      "end": "^```$",
      "beginCaptures": { "1": { "name": "entity.name.tag.language.aif" } },
      "name": "markup.fenced_code.block.aif",
      "contentName": "meta.embedded.block.code"
    },
    "table": {
      "match": "^\\s*\\|.*\\|\\s*$",
      "name": "markup.other.table.aif"
    }
  }
}

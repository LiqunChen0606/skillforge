              "title": [
                {
                  "type": "Text",
                  "text": "Decision Audit Trail"
                }
              ],
              "children": [
                {
                  "kind": {
                    "type": "Paragraph",
                    "content": [
                      {
                        "type": "Text",
                        "text": "| # | Phase | Decision | Classification | Principle | Rationale | Rejected |\n|---|-------|----------|-----------|-----------|----------|\n```\n\nWrite one row per decision incrementally (via Edit). This keeps the audit on disk,\nnot accumulated in conversation context.\n\n---"
                      }
                    ]
                  },
                  "span": {
                    "start": 0,
                    "end": 0
                  }
                }
              ]
            },
            "span": {
              "start": 0,

{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["@", "@end"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "`", "close": "`" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" }
  ],
  "surroundingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "`", "close": "`" },
    { "open": "*", "close": "*" },
    { "open": "**", "close": "**" }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*@(section|skill|claim|evidence|definition|table|callout|step|verify|precondition|example|decision|red_flag|fallback|output_contract|tool)(\\[.*\\])?(:.*)?$",
      "end": "^\\s*@end\\s*$"
    }
  }
}

        "end": 139
      }
    },
    {
      "kind": {
        "type": "Paragraph",
        "content": [
          {
            "type": "Text",
            "text": "AIF is a "
          },
          {
            "type": "Strong",
            "content": [
              {
                "type": "Text",
                "text": "semantic document format"
              }
            ]
          },
          {
            "type": "Text",
            "text": " designed for both humans and machines. Unlike Markdown, AIF natively supports structured blocks like claims, evidence, and definitions."
          }
        ]
      },
      "span": {
        "start": 141,
        "end": 314
      }
    },
    {
      "kind": {
        "type": "SemanticBlock",
        "block_type": "Claim",
        "attrs": {
          "id": "c1",
          "pairs": {}
        },
        "title": null,
        "content": [
          {
            "type": "Text",
            "text": "AIF preserves document "
          },
          {
            "type": "Emphasis",
            "content": [
              {
                "type": "Text",
                "text": "meaning"
              }
            ]
          },
          {
            "type": "Text",
            "text": ", not just appearance."
          }
        ]
      },
      "span": {
        "start": 316,
        "end": 384
      }
    },
    {
      "kind": {
        "type": "Section",

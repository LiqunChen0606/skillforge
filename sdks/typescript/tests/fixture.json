    {
      "kind": {
        "type": "List",
        "ordered": false,
        "items": [
          {
            "content": [
              {
                "type": "Text",
                "text": "Human-readable surface syntax"
              }
            ],
            "children": []
          },
          {
            "content": [
              {
                "type": "Text",
                "text": "Semantic block types for structured content"
              }
            ],
            "children": []
          },
          {
            "content": [
              {
                "type": "Text",
                "text": "Multiple output targets: HTML, Markdown, LML, JSON"
              }
            ],
            "children": []
          },
          {
            "content": [
              {
                "type": "Text",
                "text": "Lossless round-trip through the IR"
